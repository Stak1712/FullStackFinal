APP_NAME=AI Interview Platform
API_V1_PREFIX=/api/v1
ENV=dev
DEBUG=true
JWT_SECRET=dev_secret_change_me
DATABASE_URL=sqlite:///./data/app.db
ACCESS_TOKEN_EXPIRES_SECONDS=900
REFRESH_TOKEN_EXPIRES_DAYS=7

# Для обычного локального запуска без Docker используйте local.
# В docker-compose ниже переопределяется STORAGE_PROVIDER=s3 и используется MinIO.
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=./data/object_storage
STORAGE_SIGNED_URL_EXPIRES_SECONDS=900
STORAGE_MAX_FILE_SIZE_MB=10
STORAGE_S3_BUCKET=ai-interview-assets
STORAGE_S3_ENDPOINT_URL=http://127.0.0.1:9000
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=minioadmin
STORAGE_S3_SECRET_KEY=minioadmin

PUBLIC_SITE_URL=http://localhost:5173

GITHUB_API_URL=https://api.github.com
# Optional. Fill this in only if GitHub rate limits unauthenticated requests.
GITHUB_API_TOKEN=
EXTERNAL_API_TIMEOUT_SECONDS=5
EXTERNAL_API_RETRIES=2
EXTERNAL_API_RATE_LIMIT_PER_MINUTE=30
EXTERNAL_API_CACHE_TTL_SECONDS=300
